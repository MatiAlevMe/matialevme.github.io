---
export interface Experience {
  company: string;
  description?: string;
  role: string;
  period: string;
  stack: string[];
  highlights: string[];
  media?: { logo?: string | null };
}

export interface Props {
  items: Experience[];
}

const { items } = Astro.props;
---

<section id="experience" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold mb-2 text-center">
      <span class="text-primary">/</span> Experiencia
    </h2>
    <p class="text-gray-500 text-center mb-16">Trayectoria profesional</p>

    <div class="relative">
      <div class="absolute left-0 sm:left-8 top-0 bottom-0 w-px bg-gradient-to-b from-primary/40 via-white/10 to-transparent" />

      <div class="space-y-12">
        {items.map((exp) => (
          <div class="relative pl-0 sm:pl-20" key={`${exp.company}-${exp.role}`}>
            <div class="absolute left-0 sm:left-6 top-1 w-4 h-4 rounded-full bg-primary border-4 border-surface shadow-lg shadow-primary/20" />

            <div class="bg-white/[0.03] border border-white/5 rounded-2xl p-6 hover:bg-white/[0.05] transition-all">
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-4">
                <div>
                  <h3 class="text-xl font-semibold text-white">{exp.company}</h3>
                  <p class="text-primary font-medium">{exp.role}</p>
                  {exp.description && (
                    <p class="text-gray-500 text-sm mt-1">{exp.description}</p>
                  )}
                </div>
                <span class="text-sm text-gray-500 whitespace-nowrap px-3 py-1 bg-white/5 rounded-full">{exp.period}</span>
              </div>

              {exp.highlights.length > 0 && (
                <ul class="space-y-2 mb-4">
                  {exp.highlights.map((h, i) => (
                    <li class="flex items-start gap-2 text-sm text-gray-400" key={i}>
                      <span class="text-primary mt-1.5 shrink-0">&#9656;</span>
                      {h}
                    </li>
                  ))}
                </ul>
              )}

              {exp.stack.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {exp.stack.map((tech) => (
                    <span class="px-2.5 py-1 text-xs bg-primary/10 text-primary rounded-lg" key={tech}>
                      {tech}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
