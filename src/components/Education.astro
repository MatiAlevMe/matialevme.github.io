---
export interface EducationItem {
  institution: string;
  degree: string;
  period: string;
  details: string[];
  logo?: string | null;
}

export interface Certification {
  name: string;
  issuer: string;
  date: string;
  url?: string | null;
}

export interface Props {
  education: EducationItem[];
  certifications: Certification[];
}

const { education, certifications } = Astro.props;
---

<section id="education" class="py-24 px-4 bg-white/[0.01]">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold mb-2 text-center">
      <span class="text-primary">/</span> Educaci&oacute;n
    </h2>
    <p class="text-gray-500 text-center mb-16">Formaci&oacute;n acad&eacute;mica</p>

    <div class="space-y-6 mb-16">
      {education.map((edu) => (
        <div class="bg-white/[0.03] border border-white/5 rounded-2xl p-6" key={edu.institution}>
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
            <div>
              <h3 class="text-lg font-semibold text-white">{edu.institution}</h3>
              <p class="text-primary font-medium">{edu.degree}</p>
            </div>
            <span class="text-sm text-gray-500 whitespace-nowrap">{edu.period}</span>
          </div>
          {edu.details.length > 0 && (
            <ul class="space-y-1">
              {edu.details.map((d, i) => (
                <li class="text-sm text-gray-400 flex items-start gap-2" key={i}>
                  <span class="text-primary mt-1">&#9656;</span>
                  {d}
                </li>
              ))}
            </ul>
          )}
        </div>
      ))}
    </div>

    {certifications.length > 0 && (
      <>
        <h3 class="text-xl font-semibold text-gray-300 mb-6">Certificaciones</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {certifications.map((cert) => (
            <div class="bg-white/[0.03] border border-white/5 rounded-xl p-4 flex items-start gap-3" key={cert.name}>
              <svg class="w-5 h-5 text-accent mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
              </svg>
              <div>
                <p class="text-sm font-medium text-gray-200">{cert.name}</p>
                <p class="text-xs text-gray-500">{cert.issuer} &middot; {cert.date}</p>
                {cert.url && (
                  <a href={cert.url} target="_blank" rel="noopener" class="text-xs text-primary hover:underline mt-1 inline-block">
                    Ver certificado &rarr;
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>
