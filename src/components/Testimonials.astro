---
export interface TestimonialContact {
  email?: string | null;
  phone?: string | null;
  linkedin?: string | null;
}

export interface Testimonial {
  name: string;
  role?: string | null;
  company: string;
  text?: string | null;
  contact?: TestimonialContact;
}

export interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
---

<section id="testimonials" class="py-24 px-4">
  <div class="max-w-4xl mx-auto">
    <h2 class="text-3xl sm:text-4xl font-bold mb-2 text-center">
      <span class="text-primary">/</span> Recomendaciones
    </h2>
    <p class="text-gray-500 text-center mb-16">Referencias profesionales</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {items.map((t) => (
        <div class="bg-white/[0.03] border border-white/5 rounded-2xl p-6 hover:bg-white/[0.05] transition-all" key={t.name}>
          {t.text && (
            <blockquote class="text-sm text-gray-400 italic mb-4 leading-relaxed">
              &ldquo;{t.text}&rdquo;
            </blockquote>
          )}
          <div>
            <p class="text-sm font-medium text-white">{t.name}</p>
            <p class="text-xs text-gray-500">
              {t.role && `${t.role} `}
              <span class="text-primary">{t.company}</span>
            </p>
          </div>
          {t.contact && (
            <div class="mt-3 flex flex-wrap gap-2">
              {t.contact.linkedin && (
                <a href={t.contact.linkedin} target="_blank" rel="noopener" class="text-xs text-gray-500 hover:text-primary transition-colors">
                  LinkedIn &rarr;
                </a>
              )}
              {t.contact.email && (
                <span class="text-xs text-gray-500">{t.contact.email}</span>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
