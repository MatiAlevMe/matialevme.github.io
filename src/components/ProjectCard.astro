---
export interface Project {
  name: string;
  status: string;
  featured: boolean;
  stack: string[];
  description: string;
  achievement?: string | null;
  image?: string | null;
  videoUrl?: string | null;
  demoUrl?: string | null;
  githubUrl?: string | null;
  presentationUrl?: string | null;
}

export interface Props {
  project: Project;
}

const { project: p } = Astro.props;
---

<div class="group bg-white/[0.03] border border-white/5 rounded-2xl overflow-hidden hover:border-primary/30 hover:bg-white/[0.06] transition-all duration-300">
  <div class="aspect-video bg-surface overflow-hidden">
    {p.image ? (
      <img
        src={p.image}
        alt={p.name}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center bg-gradient-to-br from-primary/20 to-accent/10">
        <span class="text-5xl font-bold text-primary/40 select-none">
          {p.name.split(/[\s-]+/).map(w => w[0]).join("").slice(0, 3).toUpperCase()}
        </span>
      </div>
    )}
  </div>

  <div class="p-6">
    <div class="flex items-start justify-between gap-2 mb-3">
      <h3 class="text-lg font-semibold text-white">{p.name}</h3>
      {p.achievement && (
        <span class="shrink-0 px-2.5 py-1 text-xs bg-accent/10 text-accent rounded-lg font-medium">
          {p.achievement}
        </span>
      )}
    </div>

    <p class="text-sm text-gray-400 leading-relaxed mb-4">
      {p.description}
    </p>

    {p.stack.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-4">
        {p.stack.map((tech) => (
          <span class="px-2 py-0.5 text-xs bg-white/5 text-gray-300 rounded-md" key={tech}>
            {tech}
          </span>
        ))}
      </div>
    )}

    <div class="flex items-center gap-3">
      {p.demoUrl && (
        <a href={p.demoUrl} target="_blank" rel="noopener" class="flex items-center gap-1.5 px-4 py-2 bg-primary/10 text-primary text-sm rounded-xl hover:bg-primary/20 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          Demo
        </a>
      )}
      {p.githubUrl && (
        <a href={p.githubUrl} target="_blank" rel="noopener" class="flex items-center gap-1.5 px-4 py-2 bg-white/5 text-gray-300 text-sm rounded-xl hover:bg-white/10 transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          C&oacute;digo
        </a>
      )}
      {p.videoUrl && (
        <a href={p.videoUrl} target="_blank" rel="noopener" class="flex items-center gap-1.5 px-4 py-2 bg-white/5 text-gray-300 text-sm rounded-xl hover:bg-white/10 transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          Video
        </a>
      )}
    </div>
  </div>
</div>
